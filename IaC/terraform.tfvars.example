# terraform.tfvars
# ★ このファイルは .gitignore に追加すること（APIキーを含むため）

project_id     = "weavecaststudio"
region         = "asia-northeast1"
zone           = "asia-northeast1-b"
instance_name  = "weavecast-collector"
machine_type   = "e2-small"
disk_size_gb   = 30
bucket_name    = "weavecaststudio-sync"
google_api_key = "your-api-key-here"  # ← 実際のキーに置換
