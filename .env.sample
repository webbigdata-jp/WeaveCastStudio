# WeaveCastStudio — environment variables
# Copy this file to .env and fill in your values.

# ── Gemini API ────────────────────────────────────────────────
GOOGLE_API_KEY=your_api_key_here

# ── Output language ───────────────────────────────────────────
# BCP-47 language code used across all modules:
#   - Passed directly to the Live API (M4) as the session language code.
#   - Converted to a natural-language name (e.g. "Japanese") and injected
#     into Gemini prompts so that generated text, narration scripts, and
#     image captions are produced in the chosen language.
#
# Supported codes (subset): en, ja, ko, zh, fr, de, es, pt, ar, hi, ...
# Full list: https://ai.google.dev/gemini-api/docs/live-api/capabilities#supported-languages
#
LANGUAGE=ja
